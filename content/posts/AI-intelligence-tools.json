xl p-6 bg-white dark:bg-gray-900/50 shadow-inner md:col-span-2 lg:col-span-2 lg:w-3/4 lg:mx-auto\">\n            <h3 class=\"font-black text-xl mb-6 text-red-600 dark:text-red-500 border-b border-gray-100 dark:border-slate-800 pb-3\"><i class=\"fas fa-comments ml-2\"></i> روبوتات البرمجة (LLM Chats)</h3>\n            \n            <div class=\"grid grid-cols-2 sm:grid-cols-3 gap-3\">\n                <a href=\"https://chatgpt.com/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"bg-gray-100 dark:bg-slate-800 p-3 rounded-xl text-center font-bold text-sm text-gray-800 dark:text-white hover:bg-red-600 hover:text-white transition-colors\">ChatGPT</a>\n                <a href=\"https://claude.ai/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"bg-gray-100 dark:bg-slate-800 p-3 rounded-xl text-center font-bold text-sm text-gray-800 dark:text-white hover:bg-red-600 hover:text-white transition-colors\">Claude</a>\n                <a href=\"https://gemini.google/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"bg-gray-100 dark:bg-slate-800 p-3 rounded-xl text-center font-bold text-sm text-gray-800 dark:text-white hover:bg-red-600 hover:text-white transition-colors\">Gemini</a>\n                <a href=\"https://www.perplexity.ai/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"bg-gray-100 dark:bg-slate-800 p-3 rounded-xl text-center font-bold text-sm text-gray-800 dark:text-white hover:bg-red-600 hover:text-white transition-colors\">Perplexity</a>\n                <a href=\"https://cody.dev/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"bg-gray-100 dark:bg-slate-800 p-3 rounded-xl text-center font-bold text-sm text-gray-800 dark:text-white hover:bg-red-600 hover:text-white transition-colors\">Cody</a>\n                <a href=\"https://www.phind.com/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"bg-gray-100 dark:bg-slate-800 p-3 rounded-xl text-center font-bold text-sm text-gray-800 dark:text-white hover:bg-red-600 hover:tex