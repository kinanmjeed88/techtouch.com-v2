w-hidden border border-gray-700 shadow-lg\">\n          <div class=\"bg-[#2d2d2d] px-4 py-2 flex justify-between items-center border-b border-gray-700\">\n              <div class=\"flex gap-1.5\">\n                  <span class=\"w-3 h-3 rounded-full bg-red-500\"></span>\n                  <span class=\"w-3 h-3 rounded-full bg-yellow-500\"></span>\n                  <span class=\"w-3 h-3 rounded-full bg-green-500\"></span>\n              </div>\n              <span class=\"text-xs text-gray-400 font-mono\">TV Downloader Code</span>\n          </div>\n          <div class=\"p-5 overflow-x-auto text-left leading-loose\">\n              <pre><code class=\"font-mono text-sm text-[#a9b7c6] whitespace-pre-wrap\">📺 كود تطبيق 1 IRAQ TV:\n<span class=\"text-green-400 font-bold text-xl\">7794196</span></code></pre>\n          </div>\n      </div>\n    </div>\n    \n    <div class=\"bg-amber-50 dark:bg-amber-900/20 border-r-4 border-amber-500 p-5 mt-6 rounded-l-lg shadow-sm\">\n      <div class=\"flex items-start gap-3\">\n        <span class=\"text-2xl leading-none mt-1\">⚠️</span>\n        <div class=\"text-amber-900 dark:text-amber-200 font-bold w-full\">\n          <span class=\"text-lg block mb-3 border-b border-amber-200 dark:border-amber-700/50 pb-1\">ملاحظات هامة جداً:</span>\n          <ul class=\"list-disc list-inside space-y-2 text-sm leading-relaxed opacity-95\">\n            <li>باقات (شبكتي، فيو، سوبر، وماي تي في) تعمل <strong>على شبكة إيرثلنك فقط</strong>، وفي بعض الأحيان تتوقف وتعرض المحتوى وقت البث المباشر فقط.</li>\n            <li>التطبيق <strong>لا يعمل نهائياً</strong> على الأجهزة التي تحتوي على روت (Root) أو تطبيقات التقاط وسحب الروابط.</li>\n          </ul>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"mt-10 pt-6 border-t border-gray-200 dark:border-gray-800\">\n    <a href=\"https://t.me/techtouch7/4782\" target=\"_blank\" rel=\"noopener noreferrer\"\n       class=\"flex items-center justify-center gap-3 sm:gap-4 bg-[#24