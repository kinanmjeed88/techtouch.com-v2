ke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4\"></path></svg>\n                        </div>`\n                        }\n                        <h3 class=\"app-title font-bold text-gray-800 dark:text-white text-sm line-clamp-2 pt-1\" dir=\"ltr\" style=\"text-align: right;\">${app.name}</h3>\n                    </div>\n                    <a href=\"${app.url}\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"w-full block text-center bg-gray-50 hover:bg-emerald-500 hover:text-white dark:bg-slate-900 dark:hover:bg-emerald-600 text-gray-700 dark:text-gray-300 py-2.5 rounded-xl text-sm font-bold transition-colors border border-gray-200 dark:border-slate-700 hover:border-transparent\">\n                        تحميل التطبيق\n                    </a>\n                </div>\n                `;\n            });\n            container.innerHTML = html;\n        }\n\n        renderApps(appsData);\n\n        function liveSearchApp() {\n            const query = document.getElementById('appSearch').value.toLowerCase().trim();\n            const allCards = document.querySelectorAll('.app-card');\n            let hasResults = false;\n\n            allCards.forEach(card => {\n                const appName = card.querySelector('.app-title').innerText.toLowerCase();\n                if (appName.includes(query)) {\n                    card.style.display = 'flex';\n                    hasResults = true;\n                    if(query.length > 0) {\n                        card.classList.add('ring-2', 'ring-blue-400', 'dark:ring-blue-500');\n                    } else {\n                        card.classList.remove('ring-2', 'ring-blue-400', 'dark:ring-blue-500');\n                    }\n                } else {\n                    card.style.display = 'none';\n                    card.classList.remove('ring-2', 'ring-blue-400', 'dark:ring-blue-500');\n                }\n            });\n\n            if (hasResults) {\n                noResultsMsg.classList.add('hidden');\n            } else {\n                noResultsMsg.classList.remove('hidden');\n            }\n        }\n    </script>\n\n</div>\n",
